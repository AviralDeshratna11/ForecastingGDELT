# ============================================================
# GDELT Multi-Agent Forecasting System — Environment Config
# ============================================================
# If using gcloud auth application-default login, you do NOT
# need GOOGLE_APPLICATION_CREDENTIALS at all.
# ============================================================

# ── Google Cloud ─────────────────────────────────────────────
BQ_PROJECT=gdeltnew-494100
# GOOGLE_APPLICATION_CREDENTIALS=/home/yourname/keys/gdelt-sa.json

# ── LLM Backend ──────────────────────────────────────────────
# Provider: openrouter | anthropic | openai | local
LLM_PROVIDER=openrouter

# Your OpenRouter API key (get from openrouter.ai/keys)S
OPENROUTER_API_KEY=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

# Any model slug from openrouter.ai/models, e.g:
#   anthropic/claude-sonnet-4-5
#   google/gemini-2.5-pro
#   meta-llama/llama-3.3-70b-instruct
#   mistralai/mistral-large
LLM_MODEL=anthropic/claude-sonnet-4-5

# ── TSFM Backend ─────────────────────────────────────────────
# Options: timesfm | chronos | fallback (fallback = ARIMA, always works)
TSFM_BACKEND=fallback

# ── System ───────────────────────────────────────────────────
LOG_LEVEL=INFO
DEMO_MODE=false
